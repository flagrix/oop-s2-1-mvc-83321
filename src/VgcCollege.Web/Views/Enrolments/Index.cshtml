@model IEnumerable<VgcCollege.Web.Models.CourseEnrolment>
@{ ViewData["Title"] = "Enrolments"; }
<h2>Enrolments</h2>
@if (User.IsInRole("Admin"))
{
    <a asp-action="Create" class="btn btn-primary mb-3">+ Enrol Student</a>
}
<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr><th>Student</th><th>Course</th><th>Branch</th><th>Enrol Date</th><th>Status</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var e in Model)
        {
            <tr>
                <td>@e.StudentProfile?.Name</td>
                <td>@e.Course?.Name</td>
                <td>@e.Course?.Branch?.Name</td>
                <td>@e.EnrolDate.ToString("dd/MM/yyyy")</td>
                <td><span class="badge @(e.Status == VgcCollege.Web.Models.EnrolmentStatus.Active ? "bg-success" : "bg-secondary")">@e.Status</span></td>
                <td>
                    <a asp-controller="Attendance" asp-action="Index" asp-route-enrolmentId="@e.Id" class="btn btn-sm btn-outline-primary">Attendance</a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@e.Id" class="btn btn-sm btn-warning ms-1">Edit</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
