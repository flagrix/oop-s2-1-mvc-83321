@model IEnumerable<VgcCollege.Web.Models.Branch>
@{ ViewData["Title"] = "Branches"; }
<h2>Branches</h2>
<a asp-action="CreateBranch" class="btn btn-primary mb-3">+ Add Branch</a>
<table class="table table-striped">
    <thead class="table-dark"><tr><th>Name</th><th>Address</th><th>Courses</th></tr></thead>
    <tbody>
        @foreach (var b in Model)
        {
            <tr><td>@b.Name</td><td>@b.Address</td><td>@b.Courses.Count</td></tr>
        }
    </tbody>
</table>
