@model IEnumerable<VgcCollege.Web.Models.StudentProfile>
@{ ViewData["Title"] = "Students"; }
<h2>Students</h2>
@if (User.IsInRole("Admin"))
{
    <a asp-action="Create" class="btn btn-primary mb-3">+ Add Student</a>
}
<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr><th>Student #</th><th>Name</th><th>Email</th><th>Phone</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var s in Model)
        {
            <tr>
                <td>@s.StudentNumber</td>
                <td>@s.Name</td>
                <td>@s.Email</td>
                <td>@s.Phone</td>
                <td>
                    <a asp-action="Details" asp-route-id="@s.Id" class="btn btn-sm btn-info">Details</a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@s.Id" class="btn btn-sm btn-warning ms-1">Edit</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
