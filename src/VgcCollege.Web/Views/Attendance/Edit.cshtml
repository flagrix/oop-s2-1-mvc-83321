@model VgcCollege.Web.Models.AttendanceRecord
@{ ViewData["Title"] = "Edit Attendance"; }
<h2>Edit Attendance Record</h2>
<p class="text-muted">Student: <strong>@Model.CourseEnrolment?.StudentProfile?.Name</strong></p>
<div class="row"><div class="col-md-4">
<form asp-action="Edit" method="post">
    <input asp-for="Id" type="hidden" /><input asp-for="CourseEnrolmentId" type="hidden" />
    <div class="mb-3"><label asp-for="WeekNumber" class="form-label"></label><input asp-for="WeekNumber" class="form-control" type="number" /></div>
    <div class="mb-3"><label asp-for="Date" class="form-label"></label><input asp-for="Date" class="form-control" type="date" /></div>
    <div class="mb-3 form-check"><input asp-for="Present" class="form-check-input" type="checkbox" /><label asp-for="Present" class="form-check-label">Present</label></div>
    <button type="submit" class="btn btn-warning">Save</button>
    <a asp-action="Index" asp-route-enrolmentId="@Model.CourseEnrolmentId" class="btn btn-secondary ms-2">Cancel</a>
</form>
</div></div>
