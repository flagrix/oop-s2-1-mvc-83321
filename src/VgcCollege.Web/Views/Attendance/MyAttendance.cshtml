@model IEnumerable<VgcCollege.Web.Models.CourseEnrolment>
@{ ViewData["Title"] = "My Attendance"; }
<h2>My Attendance</h2>
@foreach (var enrolment in Model)
{
    var total = enrolment.AttendanceRecords.Count;
    var present = enrolment.AttendanceRecords.Count(r => r.Present);
    var pct = total > 0 ? (int)Math.Round((double)present / total * 100) : 0;
    <div class="card mb-4">
        <div class="card-header"><strong>@enrolment.Course?.Name</strong></div>
        <div class="card-body">
            <p>Attendance: <strong>@present / @total (@pct%)</strong></p>
            <div class="progress mb-3" style="height:10px">
                <div class="progress-bar @(pct >= 80 ? "bg-success" : "bg-warning")" style="width:@pct%"></div>
            </div>
            <table class="table table-sm">
                <thead><tr><th>Week</th><th>Date</th><th>Present</th></tr></thead>
                <tbody>
                    @foreach (var r in enrolment.AttendanceRecords.OrderBy(r => r.WeekNumber))
                    {
                        <tr><td>Week @r.WeekNumber</td><td>@r.Date.ToString("dd/MM/yyyy")</td><td>@(r.Present ? "✅" : "❌")</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
