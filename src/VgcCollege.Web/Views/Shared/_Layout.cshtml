<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VGC</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark mb-3">
            <div class="container-fluid">
                <a class="navbar-brand text-light" asp-controller="Home" asp-action="Index">🎓 VGC</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown">Admin</a>
                                    <ul class="dropdown-menu">
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Index">Dashboard</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Branches">Branches</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Courses">Courses</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="FacultyAssignments">Faculty Assignments</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" asp-controller="Students" asp-action="Index">Students</a></li>
                                        <li><a class="dropdown-item" asp-controller="Enrolments" asp-action="Index">Enrolments</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" asp-controller="Gradebook" asp-action="Assignments">Assignments</a></li>
                                        <li><a class="dropdown-item" asp-controller="Exams" asp-action="Index">Exams</a></li>
                                    </ul>
                                </li>
                            }
                            @if (User.IsInRole("Faculty"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Students" asp-action="Index">My Students</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Enrolments" asp-action="Index">Enrolments</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Gradebook" asp-action="Assignments">Gradebook</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Exams" asp-action="Index">Exams</a></li>
                            }
                            @if (User.IsInRole("Student"))
                            {
                                <li class="nav-item"><a class="nav-link" asp-controller="Students" asp-action="MyProfile">My Profile</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Enrolments" asp-action="MyEnrolments">My Enrolments</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Attendance" asp-action="MyAttendance">My Attendance</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Gradebook" asp-action="MyGradebook">My Grades</a></li>
                                <li class="nav-item"><a class="nav-link" asp-controller="Exams" asp-action="MyExamResults">My Exams</a></li>
                            }
                        }
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer class="border-top footer text-muted text-center py-2">
        <small>Acme Global College &copy; 2024</small>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
